<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>שעון נוכחות — חישוב שכר</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700&family=Frank+Ruhl+Libre:wght@600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#17233B; --ink-soft:#4A5670; --paper:#F5F6F2; --card:#FFFFFF;
  --line:#E3E6DE; --teal:#0E7C66; --teal-soft:#E4F2EE;
  --gold:#B67E1C; --gold-bg:#FFF6DF; --gold-line:#EBCF8F;
  --red:#C2412D; --red-bg:#FBEAE6; --blue:#2B5FA8;
  --radius:10px;
}
*{box-sizing:border-box; margin:0; padding:0;}
body{
  font-family:'Heebo', 'Segoe UI', Arial, sans-serif;
  background:var(--paper); color:var(--ink); font-size:14px;
  padding-bottom:60px;
}
header{
  background:var(--ink); color:#fff; padding:14px 24px;
  display:flex; align-items:center; gap:16px; flex-wrap:wrap;
}
header h1{
  font-family:'Frank Ruhl Libre', serif; font-weight:700; font-size:22px; letter-spacing:.5px;
}
header .sub{font-size:12.5px; color:#B9C2D6; font-weight:300;}
header .save-state{margin-inline-start:auto; font-size:12px; color:#8FD4C4; transition:opacity .4s;}
.wrap{max-width:1240px; margin:0 auto; padding:18px 20px;}

/* ---- toolbar ---- */
.toolbar{
  display:flex; flex-wrap:wrap; gap:14px; align-items:flex-end;
  background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
  padding:14px 16px; margin-bottom:14px;
}
.field{display:flex; flex-direction:column; gap:4px;}
.field label{font-size:11.5px; color:var(--ink-soft); font-weight:500;}
.field input, .field select{
  font-family:inherit; font-size:14px; padding:7px 10px;
  border:1px solid var(--line); border-radius:7px; background:#fff; color:var(--ink);
  min-width:0;
}
.field input:focus, .field select:focus, td input:focus, td select:focus{
  outline:2px solid var(--teal); outline-offset:-1px;
}
.field input[type=number]{width:92px;}
.field input.tm{width:74px; text-align:center;}
button{
  font-family:inherit; font-size:13.5px; font-weight:600; cursor:pointer;
  border:1px solid var(--line); background:#fff; color:var(--ink);
  padding:8px 14px; border-radius:7px;
}
button:hover{border-color:var(--teal); color:var(--teal);}
button.primary{background:var(--teal); border-color:var(--teal); color:#fff;}
button.primary:hover{background:#0A6552; color:#fff;}
button.ghost{border:none; background:transparent; color:var(--ink-soft); padding:6px 8px;}
button.ghost:hover{color:var(--red);}
.month-nav{display:flex; align-items:center; gap:6px;}
.month-nav .mtitle{
  font-family:'Frank Ruhl Libre', serif; font-size:19px; font-weight:700;
  min-width:150px; text-align:center;
}
.month-nav .msub{display:block; font-family:'Heebo'; font-weight:400; font-size:11.5px; color:var(--ink-soft);}
.month-nav button{padding:6px 12px; font-size:16px; line-height:1;}

/* ---- table ---- */
.grid-card{background:var(--card); border:1px solid var(--line); border-radius:var(--radius); overflow:auto;}
table{border-collapse:collapse; width:100%; min-width:1080px;}
thead th{
  position:sticky; top:0; background:var(--ink); color:#fff; font-weight:500;
  font-size:12px; padding:9px 6px; text-align:center; white-space:nowrap; z-index:2;
}
thead th.grp-reg{background:#22304E;}
thead th.grp-shb{background:#5C4A14;}
tbody td{
  border-bottom:1px solid var(--line); padding:4px 6px; text-align:center;
  font-variant-numeric:tabular-nums; white-space:nowrap;
}
tbody tr:hover td{background:rgba(14,124,102,.05);}
tr.shabbat td{background:var(--gold-bg);}
tr.shabbat:hover td{background:#FBEECB;}
tr.holiday td{background:var(--gold-bg); border-bottom-color:var(--gold-line);}
tr.holiday td:first-child{box-shadow:inset 4px 0 0 var(--gold);}
tr.offday td{color:#9AA3B5;}
td .daycell{display:flex; flex-direction:column; align-items:flex-start; gap:1px; text-align:right;}
td .gdate{font-weight:600;}
td .hdate{font-size:11px; color:var(--ink-soft);}
.badge{
  display:inline-block; font-size:10.5px; font-weight:700; padding:1px 7px; border-radius:20px;
  margin-top:1px;
}
.badge.chag{background:var(--gold); color:#fff;}
.badge.erev{background:#fff; color:var(--gold); border:1px solid var(--gold);}
.badge.shb{background:#E9D9A8; color:#6B5410;}
td input.tm{
  width:64px; text-align:center; font-family:inherit; font-size:13.5px;
  border:1px solid var(--line); background:#fff; border-radius:6px; padding:5px 2px;
  color:var(--ink); font-variant-numeric:tabular-nums;
}
td input.tm:hover{border-color:var(--teal);}
td input.tm:disabled{background:transparent; border-color:transparent;}
td input.tm::placeholder{color:#C3C9D4;}
td select.dtype{
  font-family:inherit; font-size:12px; border:1px solid transparent; background:transparent;
  border-radius:6px; padding:4px 2px; color:var(--ink-soft); max-width:90px;
}
td select.dtype:hover{border-color:var(--line); background:#fff;}
td.num{font-size:13px;}
td.total{font-weight:700;}
td.pos{color:var(--teal); font-weight:600;}
td.neg{color:var(--red); font-weight:600;}
td.muted{color:#B5BCC9;}
tfoot td{
  background:#EEF1EA; font-weight:700; padding:9px 6px; border-top:2px solid var(--ink);
  font-variant-numeric:tabular-nums;
}

/* ---- summary ---- */
.summary{display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:10px; margin-top:14px;}
.sumcard{
  background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
  padding:12px 14px;
}
.sumcard .k{font-size:11.5px; color:var(--ink-soft); font-weight:500;}
.sumcard .v{font-size:21px; font-weight:700; font-variant-numeric:tabular-nums; margin-top:2px;}
.sumcard .m{font-size:11px; color:var(--ink-soft); margin-top:2px;}
.sumcard.gold{border-color:var(--gold-line); background:var(--gold-bg);}
.sumcard.pay{border-color:var(--teal); background:var(--teal-soft);}
.sumcard.pay .v{color:var(--teal);}
.hint{font-size:11.5px; color:var(--ink-soft); margin-top:10px; line-height:1.6;}
.hint b{color:var(--ink);}
dialog{
  border:none; border-radius:12px; padding:22px; max-width:420px; width:92%;
  box-shadow:0 20px 60px rgba(23,35,59,.3);
}
dialog::backdrop{background:rgba(23,35,59,.45);}
dialog h3{font-family:'Frank Ruhl Libre',serif; margin-bottom:14px;}
dialog .field{margin-bottom:10px;}
dialog .row{display:flex; gap:10px;}
dialog .actions{display:flex; gap:10px; justify-content:flex-start; margin-top:16px;}
.kbd{
  background:#EEF1EA; border:1px solid var(--line); border-radius:4px; padding:0 5px;
  font-size:11px; font-family:inherit;
}
@media (max-width:760px){
  header h1{font-size:18px;}
  .toolbar{gap:10px;}
}
</style>
</head>
<body>

<header>
  <h1>פנקס נוכחות</h1>
  <span class="sub">חישוב שעות לפי חוק שעות עבודה ומנוחה · לוח שנה עברי מובנה · הנתונים נשמרים בדפדפן זה בלבד</span>
  <span class="save-state" id="saveState"></span>
</header>

<div class="wrap">

  <!-- ===== Toolbar ===== -->
  <div class="toolbar">
    <div class="field">
      <label>מעסיק</label>
      <div style="display:flex; gap:6px;">
        <select id="orgSelect" style="min-width:150px;"></select>
        <button id="btnAddOrg" title="הוספת מעסיק">＋</button>
        <button id="btnEditOrg" title="עריכת המעסיק">⚙</button>
        <button id="btnDelOrg" class="ghost" title="מחיקת מעסיק">🗑</button>
      </div>
    </div>

    <div class="field">
      <label>עובד</label>
      <div style="display:flex; gap:6px;">
        <select id="empSelect" style="min-width:170px;"></select>
        <button id="btnAddEmp" title="הוספת עובד">＋</button>
        <button id="btnEditEmp" title="עריכת הגדרות העובד">⚙</button>
        <button id="btnDelEmp" class="ghost" title="מחיקת עובד">🗑</button>
      </div>
    </div>

    <div class="month-nav">
      <button id="prevM" title="חודש קודם">‹</button>
      <div class="mtitle" id="monthTitle">—<span class="msub" id="monthSub"></span></div>
      <button id="nextM" title="חודש הבא">›</button>
    </div>

    <div class="field">
      <label>תעריף לשעה (₪)</label>
      <input type="number" id="wage" min="0" step="0.5" placeholder="למשל 40">
    </div>

    <div style="margin-inline-start:auto; display:flex; gap:8px; align-items:flex-end;">
      <button id="btnClear">ניקוי החודש</button>
      <button id="btnExport" class="primary">ייצוא לאקסל (CSV)</button>
    </div>
  </div>

  <!-- ===== Grid ===== -->
  <div class="grid-card">
    <table id="grid">
      <thead>
        <tr>
          <th style="text-align:right; padding-inline-start:12px;">תאריך</th>
          <th>סוג יום</th>
          <th>כניסה</th>
          <th>יציאה</th>
          <th>הפסקה</th>
          <th>תקן</th>
          <th>סה"כ</th>
          <th class="grp-reg">100%</th>
          <th class="grp-reg">125%</th>
          <th class="grp-reg">150%</th>
          <th class="grp-shb">שבת/חג 150%</th>
          <th class="grp-shb">175%</th>
          <th class="grp-shb">200%</th>
          <th>חוסר/עודף</th>
        </tr>
      </thead>
      <tbody id="gridBody"></tbody>
      <tfoot id="gridFoot"></tfoot>
    </table>
  </div>

  <!-- ===== Summary ===== -->
  <div class="summary" id="summary"></div>

  <p class="hint">
    <b>קיצורי הזנה:</b> הקלידו <span class="kbd">8</span> ← 08:00 · <span class="kbd">830</span> ← 08:30 · <span class="kbd">8.15</span> ← 08:15 ·
    <b>דאבל-קליק</b> על שדה שעה ממלא את השעה הנוכחית · <span class="kbd">Enter</span> עובר לשדה הבא.
    <br>
    <b>שיטת החישוב:</b> שעתיים נוספות ראשונות ביום — 125%, מהשלישית — 150% (ס' 16 לחוק שעות עבודה ומנוחה) ·
    עבודה בשבת/חג — 150% עד התקן, ואחריו 175% לשעתיים ו-200% הלאה (ע"ע 300175/97 כהן – עיריית נהריה) ·
    חגים וערבי חג מזוהים אוטומטית לפי הלוח העברי; ניתן לשנות ידנית בעמודת "סוג יום".
  </p>

</div>

<!-- ===== Employee dialog ===== -->
<dialog id="empDialog">
  <h3 id="empDlgTitle">עובד חדש</h3>
  <div class="field"><label>שם העובד</label><input id="empName" placeholder="למשל: ישראל ישראלי"></div>
  <div class="row">
    <div class="field"><label>תעריף לשעה (₪)</label><input type="number" id="empWage" min="0" step="0.5"></div>
    <div class="field"><label>שבוע עבודה</label>
      <select id="empWeek"><option value="5">5 ימים (א׳–ה׳)</option><option value="6">6 ימים (א׳–ו׳)</option></select>
    </div>
  </div>
  <div class="row">
    <div class="field"><label>תקן יומי (יום רגיל)</label><input class="tm" id="empStd" value="08:36"></div>
    <div class="field"><label>תקן שישי / ערב חג</label><input class="tm" id="empFri" value="07:00"></div>
  </div>
  <div class="field"><label>ניכוי הפסקה אוטומטי (דקות, 0 = ללא)</label><input type="number" id="empBreak" min="0" step="5" value="0"></div>
  <div class="actions">
    <button class="primary" id="empSave">שמירה</button>
    <button id="empCancel">ביטול</button>
  </div>
</dialog>

<!-- ===== Employer dialog ===== -->
<dialog id="orgDialog">
  <h3 id="orgDlgTitle">מעסיק חדש</h3>
  <div class="field"><label>שם המעסיק / העסק</label><input id="orgName" placeholder="למשל: מאפיית הכיכר בע״מ"></div>
  <div class="row">
    <div class="field"><label>ח.פ / עוסק מורשה (רשות)</label><input id="orgHp" placeholder="למשל: 512345678"></div>
    <div class="field"><label>איש קשר (רשות)</label><input id="orgContact" placeholder="שם וטלפון"></div>
  </div>
  <div class="actions">
    <button class="primary" id="orgSave">שמירה</button>
    <button id="orgCancel">ביטול</button>
  </div>
</dialog>

<script>
/* ================= Hebrew calendar ================= */
const hebFmtEn = new Intl.DateTimeFormat('en-u-ca-hebrew', {month:'long', day:'numeric'});
const hebFmtHe = new Intl.DateTimeFormat('he-u-ca-hebrew', {month:'long', day:'numeric'});
function hebParts(d){
  const parts = hebFmtEn.formatToParts(d);
  return {
    m: parts.find(p=>p.type==='month').value,
    d: +parts.find(p=>p.type==='day').value
  };
}
// Full rest-day holidays (dinam like Shabbat for pay)
function holidayName(d){
  const h = hebParts(d), wd = d.getDay();
  if(h.m==='Tishri'){
    if(h.d===1||h.d===2) return 'ראש השנה';
    if(h.d===10) return 'יום הכיפורים';
    if(h.d===15) return 'סוכות';
    if(h.d===22) return 'שמחת תורה';
  }
  if(h.m==='Nisan'){
    if(h.d===15) return 'פסח';
    if(h.d===21) return 'שביעי של פסח';
  }
  if(h.m==='Sivan' && h.d===6) return 'שבועות';
  if(h.m==='Iyar'){ // Independence Day, observed date shifts
    if(h.d===5 && wd!==5 && wd!==6 && wd!==1) return 'יום העצמאות';
    if(h.d===4 && wd===4) return 'יום העצמאות'; // 5 Iyar falls Friday
    if(h.d===3 && wd===4) return 'יום העצמאות'; // 5 Iyar falls Saturday
    if(h.d===6 && wd===2) return 'יום העצמאות'; // 5 Iyar falls Monday
  }
  return null;
}
function erevName(d){
  const h = hebParts(d);
  if(h.m==='Elul' && h.d===29) return 'ערב ראש השנה';
  if(h.m==='Tishri'){
    if(h.d===9) return 'ערב יום כיפור';
    if(h.d===14) return 'ערב סוכות';
    if(h.d===21) return 'הושענא רבה';
  }
  if(h.m==='Nisan'){
    if(h.d===14) return 'ערב פסח';
    if(h.d===20) return 'ערב שביעי של פסח';
  }
  if(h.m==='Sivan' && h.d===5) return 'ערב שבועות';
  return null;
}
function cholHamoed(d){
  const h = hebParts(d);
  if(h.m==='Tishri' && h.d>=16 && h.d<=20) return 'חול המועד סוכות';
  if(h.m==='Nisan' && h.d>=16 && h.d<=19) return 'חול המועד פסח';
  return null;
}

/* ================= time helpers ================= */
const pad = n => String(n).padStart(2,'0');
function parseTime(v){          // -> minutes or null
  if(v==null) return null;
  v = String(v).trim().replace(/[.,]/g,':');
  if(v==='') return null;
  let h,m;
  if(/^\d{1,2}$/.test(v)){ h=+v; m=0; }
  else if(/^\d{3,4}$/.test(v)){ h=+v.slice(0,v.length-2); m=+v.slice(-2); }
  else if(/^\d{1,2}:\d{1,2}$/.test(v)){ const p=v.split(':'); h=+p[0]; m=+p[1]; }
  else return null;
  if(h>23||m>59) return null;
  return h*60+m;
}
const fmtHM  = mins => mins==null ? '' : pad(Math.floor(mins/60))+':'+pad(mins%60);
const fmtDur = mins => (mins<0?'-':'') + Math.floor(Math.abs(mins)/60) + ':' + pad(Math.abs(mins)%60);
const durOrDash = mins => mins>0 ? fmtDur(mins) : '';

/* ================= state & storage ================= */
let employers = [];             // {id,name,hp,contact}
let curOrgId = null;
let employees = [];             // {id,orgId,name,wage,week,std,fri,brk}
let curEmpId = null;
let curYear, curMonth;          // month 0-11
let rows = {};                  // dayNum -> {type,in,out,brk}
let saveTimer = null;
const memStore = {};            // fallback if window.storage unavailable

async function stGet(k){
  try{ const v = localStorage.getItem('tc:'+k); if(v!=null) return JSON.parse(v); }catch(e){}
  return memStore[k]!==undefined ? JSON.parse(memStore[k]) : null;
}
async function stSet(k,val){
  const s = JSON.stringify(val);
  try{ localStorage.setItem('tc:'+k, s); }catch(e){}
  memStore[k]=s; flashSaved();
}
function flashSaved(){
  const el = document.getElementById('saveState');
  el.textContent = '✓ נשמר';
  el.style.opacity = 1;
  clearTimeout(flashSaved.t);
  flashSaved.t = setTimeout(()=>el.style.opacity=0, 1800);
}
const monthKey = () => `data:${curEmpId}:${curYear}-${pad(curMonth+1)}`;

function scheduleSave(){
  clearTimeout(saveTimer);
  saveTimer = setTimeout(async ()=>{
    if(curEmpId) await stSet(monthKey(), rows);
  }, 500);
}

/* ================= employees ================= */
const $ = id => document.getElementById(id);
const dayLetters = ['א','ב','ג','ד','ה','ו','ש'];
const monthNames = ['ינואר','פברואר','מרץ','אפריל','מאי','יוני','יולי','אוגוסט','ספטמבר','אוקטובר','נובמבר','דצמבר'];

function emp(){ return employees.find(e=>e.id===curEmpId); }
function org(){ return employers.find(o=>o.id===curOrgId); }
function empsOfOrg(){ return employees.filter(e=>e.orgId===curOrgId); }

/* ---- employers ---- */
function renderOrgSelect(){
  const sel = $('orgSelect');
  sel.innerHTML = '';
  if(!employers.length){
    sel.innerHTML = '<option value="">— הוסיפו מעסיק —</option>';
    return;
  }
  employers.forEach(o=>{
    const opt = document.createElement('option');
    opt.value = o.id; opt.textContent = o.name;
    sel.appendChild(opt);
  });
  sel.value = curOrgId;
}
let editingOrgId = null;
function openOrgDialog(o){
  editingOrgId = o ? o.id : null;
  $('orgDlgTitle').textContent = o ? 'עריכת מעסיק' : 'מעסיק חדש';
  $('orgName').value = o ? o.name : '';
  $('orgHp').value = o ? (o.hp||'') : '';
  $('orgContact').value = o ? (o.contact||'') : '';
  $('orgDialog').showModal();
}
$('orgSave').addEventListener('click', async ()=>{
  const name = $('orgName').value.trim();
  if(!name){ $('orgName').focus(); return; }
  const data = { name, hp:$('orgHp').value.trim(), contact:$('orgContact').value.trim() };
  if(editingOrgId){
    Object.assign(employers.find(o=>o.id===editingOrgId), data);
  }else{
    data.id = 'o'+Date.now();
    employers.push(data);
    curOrgId = data.id;
    curEmpId = null;
  }
  await stSet('employers', employers);
  $('orgDialog').close();
  renderOrgSelect();
  curEmpId = empsOfOrg()[0]?.id || null;
  renderEmpSelect();
  await loadMonth();
});
$('orgCancel').addEventListener('click', ()=>$('orgDialog').close());
$('btnAddOrg').addEventListener('click', ()=>openOrgDialog(null));
$('btnEditOrg').addEventListener('click', ()=>{ if(org()) openOrgDialog(org()); });
$('btnDelOrg').addEventListener('click', async ()=>{
  if(!org()) return;
  const n = empsOfOrg().length;
  if(!confirm(`למחוק את המעסיק "${org().name}"${n?` יחד עם ${n} העובדים שתחתיו`:''}?`)) return;
  employees = employees.filter(e=>e.orgId!==curOrgId);
  employers = employers.filter(o=>o.id!==curOrgId);
  curOrgId = employers[0]?.id || null;
  curEmpId = empsOfOrg()[0]?.id || null;
  await stSet('employers', employers);
  await stSet('employees', employees);
  renderOrgSelect(); renderEmpSelect();
  await loadMonth();
});
$('orgSelect').addEventListener('change', async e=>{
  curOrgId = e.target.value || null;
  curEmpId = empsOfOrg()[0]?.id || null;
  renderEmpSelect();
  await loadMonth();
});

/* ---- employees ---- */
function renderEmpSelect(){
  const sel = $('empSelect');
  sel.innerHTML = '';
  const list = empsOfOrg();
  if(!list.length){
    sel.innerHTML = `<option value="">${curOrgId?'— הוסיפו עובד למעסיק זה —':'— בחרו מעסיק תחילה —'}</option>`;
    return;
  }
  list.forEach(e=>{
    const o = document.createElement('option');
    o.value = e.id; o.textContent = e.name;
    sel.appendChild(o);
  });
  sel.value = curEmpId;
}

let editingEmpId = null;
function openEmpDialog(e){
  editingEmpId = e ? e.id : null;
  $('empDlgTitle').textContent = e ? 'עריכת עובד' : 'עובד חדש';
  $('empName').value  = e ? e.name : '';
  $('empWage').value  = e ? (e.wage||'') : '';
  $('empWeek').value  = e ? e.week : '5';
  $('empStd').value   = e ? fmtHM(e.std) : '08:36';
  $('empFri').value   = e ? fmtHM(e.fri) : '07:00';
  $('empBreak').value = e ? (e.brk||0) : 0;
  $('empDialog').showModal();
}
$('empWeek').addEventListener('change', ()=>{
  // legal defaults: 5-day week → daily standard 8:36, 6-day week → 8:00
  $('empStd').value = $('empWeek').value==='5' ? '08:36' : '08:00';
});
$('empSave').addEventListener('click', async ()=>{
  const name = $('empName').value.trim();
  if(!name){ $('empName').focus(); return; }
  const data = {
    name,
    wage: parseFloat($('empWage').value)||0,
    week: $('empWeek').value,
    std:  parseTime($('empStd').value) ?? 516,
    fri:  parseTime($('empFri').value) ?? 420,
    brk:  parseInt($('empBreak').value)||0
  };
  if(editingEmpId){
    Object.assign(employees.find(e=>e.id===editingEmpId), data);
  }else{
    data.id = 'e'+Date.now();
    data.orgId = curOrgId;
    employees.push(data);
    curEmpId = data.id;
  }
  await stSet('employees', employees);
  $('empDialog').close();
  renderEmpSelect();
  await loadMonth();
});
$('empCancel').addEventListener('click', ()=>$('empDialog').close());
$('btnAddEmp').addEventListener('click', ()=>{
  if(!curOrgId){ openOrgDialog(null); return; }
  openEmpDialog(null);
});
$('btnEditEmp').addEventListener('click', ()=>{ if(emp()) openEmpDialog(emp()); });
$('btnDelEmp').addEventListener('click', async ()=>{
  if(!emp()) return;
  if(!confirm(`למחוק את ${emp().name}? נתוני החודשים שלו יוסתרו.`)) return;
  employees = employees.filter(e=>e.id!==curEmpId);
  curEmpId = empsOfOrg()[0]?.id || null;
  await stSet('employees', employees);
  renderEmpSelect();
  await loadMonth();
});
$('empSelect').addEventListener('change', async e=>{
  curEmpId = e.target.value || null;
  await loadMonth();
});
$('wage').addEventListener('change', async e=>{
  if(!emp()) return;
  emp().wage = parseFloat(e.target.value)||0;
  await stSet('employees', employees);
  render();
});

/* ================= month nav ================= */
$('prevM').addEventListener('click', ()=>shiftMonth(-1));
$('nextM').addEventListener('click', ()=>shiftMonth(1));
async function shiftMonth(dir){
  curMonth += dir;
  if(curMonth<0){ curMonth=11; curYear--; }
  if(curMonth>11){ curMonth=0; curYear++; }
  await loadMonth();
}

async function loadMonth(){
  rows = {};
  if(curEmpId){
    const saved = await stGet(monthKey());
    if(saved) rows = saved;
    $('wage').value = emp().wage || '';
  } else {
    $('wage').value = '';
  }
  render();
}

$('btnClear').addEventListener('click', async ()=>{
  if(!confirm('לנקות את כל השעות שהוזנו בחודש זה?')) return;
  rows = {};
  await stSet(monthKey(), rows);
  render();
});

/* ================= day model & calculation ================= */
function dayInfo(dnum){
  const d = new Date(curYear, curMonth, dnum);
  const wd = d.getDay();
  const chag = holidayName(d);
  const erev = erevName(d);
  const moed = cholHamoed(d);
  const e = emp() || {week:'5', std:516, fri:420};
  const isWorkday = e.week==='6' ? wd<=5 : wd<=4;
  return {
    d, wd,
    hebStr: hebFmtHe.format(d),
    chag, erev, moed,
    isShabbat: wd===6,
    isWorkday: !chag && wd!==6 && isWorkday,
    std: (wd===5 || erev) ? e.fri : e.std
  };
}

function calcRow(dnum){
  const info = dayInfo(dnum);
  const r = rows[dnum] || {};
  const type = r.type || 'auto';
  const out = {h100:0,h125:0,h150:0,s150:0,s175:0,s200:0,total:0,diff:null,absStd:0,info};

  // manual overrides
  const isRest = type==='auto' ? (info.isShabbat || !!info.chag) : (type==='chag');
  const isAbs  = ['vac','sick','milu'].includes(type);

  if(isAbs){
    out.absStd = info.std;         // paid absence at 100%, tallied separately
    return out;
  }
  const tin = parseTime(r.in), tout = parseTime(r.out);
  if(tin==null || tout==null){
    if(info.isWorkday && type==='auto') out.diff = -info.std; // full missing day (informational)
    out.empty = true;
    return out;
  }
  let brk = parseTime(r.brk);
  if(brk==null) brk = (emp()?.brk||0);
  let total = tout - tin; if(total<0) total += 1440;
  total = Math.max(0, total - brk);
  out.total = total;

  const std = info.std;
  if(isRest){
    out.s150 = Math.min(total, std);
    const ot = Math.max(0, total-std);
    out.s175 = Math.min(ot, 120);
    out.s200 = Math.max(0, ot-120);
  }else{
    out.h100 = Math.min(total, std);
    const ot = Math.max(0, total-std);
    out.h125 = Math.min(ot, 120);
    out.h150 = Math.max(0, ot-120);
    out.diff = total - std;
  }
  return out;
}

/* ================= render ================= */
function render(){
  const daysInMonth = new Date(curYear, curMonth+1, 0).getDate();
  $('monthTitle').firstChild.textContent = `${monthNames[curMonth]} ${curYear}`;
  const first = hebFmtHe.format(new Date(curYear,curMonth,1));
  const last  = hebFmtHe.format(new Date(curYear,curMonth,daysInMonth));
  $('monthSub').textContent = `${first} – ${last}`;

  const body = $('gridBody');
  body.innerHTML = '';
  const T = {h100:0,h125:0,h150:0,s150:0,s175:0,s200:0,total:0,diff:0,absStd:0, workdays:0, chagDays:0, vac:0, sick:0, milu:0, stdSum:0, stdDays:0};

  if(!curEmpId){
    body.innerHTML = `<tr><td colspan="14" style="padding:40px; color:#9AA3B5;">${curOrgId?'הוסיפו עובד למעסיק זה כדי להתחיל ⤴':'הוסיפו מעסיק ראשון כדי להתחיל ⤴'}</td></tr>`;
    $('gridFoot').innerHTML = '';
    $('summary').innerHTML = '';
    return;
  }

  for(let dn=1; dn<=daysInMonth; dn++){
    const c = calcRow(dn);
    const info = c.info;
    const r = rows[dn] || {};
    const tr = document.createElement('tr');
    if(info.chag) tr.className = 'holiday';
    else if(info.isShabbat) tr.className = 'shabbat';
    else if(!info.isWorkday) tr.className = 'offday';

    let badge = '';
    if(info.chag) badge = `<span class="badge chag">🕯 ${info.chag}</span>`;
    else if(info.isShabbat) badge = `<span class="badge shb">שבת</span>`;
    else if(info.erev) badge = `<span class="badge erev">${info.erev}</span>`;
    else if(info.moed) badge = `<span class="badge erev">${info.moed}</span>`;

    const isAbs = ['vac','sick','milu'].includes(r.type);
    const dtype = r.type || 'auto';

    tr.innerHTML = `
      <td style="text-align:right; padding-inline-start:12px;">
        <div class="daycell">
          <span class="gdate">${info.wd===6?'ש':dayLetters[info.wd]}׳ · ${pad(dn)}/${pad(curMonth+1)}</span>
          <span class="hdate">${info.hebStr}</span>
          ${badge}
        </div>
      </td>
      <td>
        <select class="dtype" data-d="${dn}">
          <option value="auto" ${dtype==='auto'?'selected':''}>${info.chag||info.isShabbat?'שבת/חג':'רגיל'}</option>
          <option value="chag" ${dtype==='chag'?'selected':''}>חג (ידני)</option>
          <option value="vac"  ${dtype==='vac'?'selected':''}>חופשה</option>
          <option value="sick" ${dtype==='sick'?'selected':''}>מחלה</option>
          <option value="milu" ${dtype==='milu'?'selected':''}>מילואים</option>
        </select>
      </td>
      <td><input class="tm" data-d="${dn}" data-f="in"  value="${r.in||''}"  placeholder="--:--" ${isAbs?'disabled':''}></td>
      <td><input class="tm" data-d="${dn}" data-f="out" value="${r.out||''}" placeholder="--:--" ${isAbs?'disabled':''}></td>
      <td><input class="tm" data-d="${dn}" data-f="brk" value="${r.brk||''}" placeholder="${emp().brk?fmtHM(emp().brk):'00:00'}" ${isAbs?'disabled':''}></td>
      <td class="num muted">${info.isWorkday||info.isShabbat||info.chag? fmtDur(info.std):''}</td>
      <td class="num total">${isAbs? '<span style="color:var(--blue)">'+({vac:'חופשה',sick:'מחלה',milu:'מילואים'})[r.type]+'</span>' : durOrDash(c.total)}</td>
      <td class="num">${durOrDash(c.h100)}</td>
      <td class="num">${durOrDash(c.h125)}</td>
      <td class="num">${durOrDash(c.h150)}</td>
      <td class="num">${durOrDash(c.s150)}</td>
      <td class="num">${durOrDash(c.s175)}</td>
      <td class="num">${durOrDash(c.s200)}</td>
      <td class="num ${c.diff>0?'pos':c.diff<0?'neg':''}">${c.diff!=null&&c.diff!==0&&!c.empty? (c.diff>0?'+':'')+fmtDur(c.diff) : (c.diff!=null&&c.empty&&c.diff<0?'':'')}</td>
    `;
    body.appendChild(tr);

    // totals
    T.h100+=c.h100; T.h125+=c.h125; T.h150+=c.h150;
    T.s150+=c.s150; T.s175+=c.s175; T.s200+=c.s200;
    T.total+=c.total; T.absStd+=c.absStd;
    if(info.isWorkday){ T.stdSum += info.std; T.stdDays++; }
    if(c.total>0) T.workdays++;
    if(c.diff!=null && !c.empty) T.diff += c.diff;
    if(r.type==='vac') T.vac++;
    if(r.type==='sick') T.sick++;
    if(r.type==='milu') T.milu++;
    if(info.chag) T.chagDays++;
  }

  $('gridFoot').innerHTML = `
    <tr>
      <td colspan="6" style="text-align:right; padding-inline-start:12px;">סה"כ חודשי</td>
      <td>${fmtDur(T.total)}</td>
      <td>${fmtDur(T.h100)}</td>
      <td>${fmtDur(T.h125)}</td>
      <td>${fmtDur(T.h150)}</td>
      <td>${fmtDur(T.s150)}</td>
      <td>${fmtDur(T.s175)}</td>
      <td>${fmtDur(T.s200)}</td>
      <td class="${T.diff>0?'pos':T.diff<0?'neg':''}">${T.diff!==0?(T.diff>0?'+':'')+fmtDur(T.diff):''}</td>
    </tr>`;

  renderSummary(T);
  bindGrid();
}

function renderSummary(T){
  const wage = emp()?.wage || 0;
  const hrs = m => m/60;
  const pay = wage>0
    ? hrs(T.h100)*wage + hrs(T.h125)*wage*1.25 + hrs(T.h150)*wage*1.5
      + hrs(T.s150)*wage*1.5 + hrs(T.s175)*wage*1.75 + hrs(T.s200)*wage*2
      + hrs(T.absStd)*wage
    : null;
  const fmtShekel = n => n.toLocaleString('he-IL',{style:'currency',currency:'ILS',maximumFractionDigits:0});
  const cards = [
    {k:'תקן חודשי (לפי הלוח)', v:fmtDur(T.stdSum), m:`${T.stdDays} ימי תקן · משרה מלאה מקובלת: 182 ש׳`},
    {k:'ימי עבודה בפועל', v:T.workdays},
    {k:'סה"כ שעות בפועל', v:fmtDur(T.total)},
    {k:'שעות 100%', v:fmtDur(T.h100)},
    {k:'נוספות 125%', v:fmtDur(T.h125)},
    {k:'נוספות 150%', v:fmtDur(T.h150)},
    {k:'שבת/חג (150/175/200)', v:fmtDur(T.s150+T.s175+T.s200), gold:true},
    {k:'היעדרות בתשלום (100%)', v:fmtDur(T.absStd), m:`חופשה ${T.vac} · מחלה ${T.sick} · מילואים ${T.milu}`},
  ];
  if(pay!=null) cards.push({k:'שכר ברוטו משוער', v:fmtShekel(pay), m:`לפי ${wage} ₪ לשעה, לפני נסיעות וזכויות נלוות`, pay:true});
  $('summary').innerHTML = cards.map(c=>`
    <div class="sumcard ${c.gold?'gold':''} ${c.pay?'pay':''}">
      <div class="k">${c.k}</div><div class="v">${c.v}</div>
      ${c.m?`<div class="m">${c.m}</div>`:''}
    </div>`).join('');
}

/* ================= grid events ================= */
function bindGrid(){
  document.querySelectorAll('#gridBody input.tm').forEach(inp=>{
    inp.addEventListener('blur', e=>{
      const mins = parseTime(e.target.value);
      e.target.value = mins==null ? '' : fmtHM(mins);
      setCell(e.target);
    });
    inp.addEventListener('keydown', e=>{
      if(e.key==='Enter'){ e.preventDefault(); focusNext(e.target); }
    });
    inp.addEventListener('dblclick', e=>{
      const now = new Date();
      e.target.value = fmtHM(now.getHours()*60+now.getMinutes());
      setCell(e.target);
    });
  });
  document.querySelectorAll('#gridBody select.dtype').forEach(sel=>{
    sel.addEventListener('change', e=>{
      const d = e.target.dataset.d;
      rows[d] = rows[d]||{};
      rows[d].type = e.target.value;
      scheduleSave();
      render();
    });
  });
}
function setCell(inp){
  const d = inp.dataset.d, f = inp.dataset.f;
  rows[d] = rows[d]||{};
  rows[d][f] = inp.value;
  scheduleSave();
  // recompute without losing focus flow
  const active = document.activeElement;
  render();
  if(active && active.dataset){ // restore focus
    const again = document.querySelector(`input.tm[data-d="${active.dataset.d}"][data-f="${active.dataset.f}"]`);
    if(again) again.focus();
  }
}
function focusNext(cur){
  const all = [...document.querySelectorAll('#gridBody input.tm:not([disabled])')];
  const i = all.indexOf(cur);
  cur.blur();
  setTimeout(()=>{
    const all2 = [...document.querySelectorAll('#gridBody input.tm:not([disabled])')];
    if(all2[i+1]) all2[i+1].focus();
  }, 0);
}

/* ================= export ================= */
$('btnExport').addEventListener('click', ()=>{
  if(!emp()) return;
  const daysInMonth = new Date(curYear, curMonth+1, 0).getDate();
  const lines = [['תאריך','יום','תאריך עברי','סימון','כניסה','יציאה','הפסקה','תקן','סה"כ','100%','125%','150%','שבת/חג 150%','175%','200%','חוסר/עודף']];
  for(let dn=1; dn<=daysInMonth; dn++){
    const c = calcRow(dn), info = c.info, r = rows[dn]||{};
    lines.push([
      `${pad(dn)}/${pad(curMonth+1)}/${curYear}`,
      dayLetters[info.wd],
      info.hebStr,
      info.chag || (info.isShabbat?'שבת':'') || info.erev || info.moed || ({vac:'חופשה',sick:'מחלה',milu:'מילואים'})[r.type] || '',
      r.in||'', r.out||'', r.brk||'',
      fmtDur(info.std),
      fmtDur(c.total), fmtDur(c.h100), fmtDur(c.h125), fmtDur(c.h150),
      fmtDur(c.s150), fmtDur(c.s175), fmtDur(c.s200),
      c.diff!=null?fmtDur(c.diff):''
    ]);
  }
  const csv = '\uFEFF' + lines.map(l=>l.map(x=>`"${String(x).replace(/"/g,'""')}"`).join(',')).join('\r\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8'}));
  a.download = `נוכחות_${org()?org().name+'_':''}${emp().name}_${pad(curMonth+1)}-${curYear}.csv`;
  a.click();
});

/* ================= init ================= */
(async function init(){
  const now = new Date();
  curYear = now.getFullYear(); curMonth = now.getMonth();
  const savedOrgs = await stGet('employers');
  if(savedOrgs && savedOrgs.length) employers = savedOrgs;
  const saved = await stGet('employees');
  if(saved && saved.length) employees = saved;

  // migration: employees created before the employer level get a default employer
  if(employees.some(e=>!e.orgId)){
    let def = employers[0];
    if(!def){ def = {id:'o-default', name:'המשרד שלי'}; employers.push(def); }
    employees.forEach(e=>{ if(!e.orgId) e.orgId = def.id; });
    await stSet('employers', employers);
    await stSet('employees', employees);
  }

  curOrgId = employers[0]?.id || null;
  curEmpId = empsOfOrg()[0]?.id || null;
  renderOrgSelect();
  renderEmpSelect();
  await loadMonth();
  if(!employers.length) openOrgDialog(null);
  else if(!empsOfOrg().length) openEmpDialog(null);
})();
</script>
